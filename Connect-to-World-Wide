import React, { useState, useEffect, useRef } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Video, 
  Mic, 
  MicOff, 
  VideoOff, 
  MessageSquare, 
  Sparkles, 
  Heart, 
  X, 
  User, 
  Camera,
  LogOut,
  Send,
  MoreVertical,
  Zap,
  TrendingUp,
  Download,
  CreditCard,
  Layers,
  Upload,
  Plus,
  Search
} from 'lucide-react';

// --- Types ---
type Screen = 'landing' | 'lobby' | 'call' | 'video-platform' | 'dashboard';

interface VideoItem {
  id: string;
  title: string;
  description: string;
  script?: string;
  category: string;
  thumbnailColor: string;
  price: number;
  downloads: number;
  videoUrl?: string;
  trailerUrl?: string;
  mock?: boolean;
}

interface SaleRecord {
  date: string;
  movieTitle: string;
  amount: number;
  buyer: string;
  isRecurring?: boolean;
}

// --- Components ---

const Button = ({ 
  children, 
  onClick, 
  variant = 'primary', 
  className = '',
  disabled = false
}: { 
  children: React.ReactNode; 
  onClick?: () => void; 
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger' | 'success';
  className?: string;
  disabled?: boolean;
}) => {
  const base = "px-6 py-3 rounded-full font-medium transition-all flex items-center justify-center gap-2 active:scale-95 disabled:opacity-50 disabled:pointer-events-none";
  const variants = {
    primary: "bg-brand-500 text-white hover:bg-brand-600 shadow-lg shadow-brand-500/20",
    secondary: "bg-white text-brand-600 hover:bg-brand-50 shadow-sm",
    outline: "border-2 border-brand-200 text-brand-600 hover:bg-brand-50",
    ghost: "text-slate-600 hover:bg-slate-100",
    danger: "bg-rose-500 text-white hover:bg-rose-600 shadow-lg shadow-rose-500/20",
    success: "bg-emerald-500 text-white hover:bg-emerald-600 shadow-lg shadow-emerald-500/20",
  };

  return (
    <button 
      onClick={onClick} 
      className={`${base} ${variants[variant]} ${className}`}
      disabled={disabled}
    >
      {children}
    </button>
  );
};

export default function App() {
  const [screen, setScreen] = useState<Screen>('landing');
  const [userName, setUserName] = useState('');
  const [isMuted, setIsMuted] = useState(false);
  const [isVideoOff, setIsVideoOff] = useState(false);
  const [icebreaker, setIcebreaker] = useState<string | null>(null);
  const [isLoadingIcebreaker, setIsLoadingIcebreaker] = useState(false);
  
  // Platform Owner / Store State
  const [videoPrompt, setVideoPrompt] = useState('');
  const [generating, setGenerating] = useState(false);
  const [generatedVideo, setGeneratedVideo] = useState<VideoItem | null>(null);
  const [platformRevenue, setPlatformRevenue] = useState(0);
  const [adsRevenue, setAdsRevenue] = useState(0);
  const [watchRevenue, setWatchRevenue] = useState(0);
  const [donationRevenue, setDonationRevenue] = useState(0);
  const [recurringRevenue, setRecurringRevenue] = useState(0);
  const [activeDonors, setActiveDonors] = useState(0);
  const [salesHistory, setSalesHistory] = useState<SaleRecord[]>([]);
  const [isDownloading, setIsDownloading] = useState(false);
  const [selectedCategory, setSelectedCategory] = useState('All');
  const [downloadProgress, setDownloadProgress] = useState(0);
  const [searchQuery, setSearchQuery] = useState('');
  const [activeTrailer, setActiveTrailer] = useState<VideoItem | null>(null);

  // Upload State
  const [uploadTitle, setUploadTitle] = useState('');
  const [uploadDesc, setUploadDesc] = useState('');
  const [uploadCategory, setUploadCategory] = useState('News');
  const [isUploadingManual, setIsUploadingManual] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);

  // Withdrawal State
  const [withdrawAmount, setWithdrawAmount] = useState('');
  const [momoNumber, setMomoNumber] = useState('');
  const [isProcessingWithdrawal, setIsProcessingWithdrawal] = useState(false);

  const videoRef = useRef<HTMLVideoElement>(null);

  const categories = ['All', 'News', 'Nature', 'Tech', 'Comedy', 'Drama', 'Travel'];

  // Default Movies
  const [movies, setMovies] = useState<VideoItem[]>([
    { 
      id: '1', 
      title: 'Global News Weekly', 
      description: "Breaking stories from around the globe.", 
      category: 'News', 
      thumbnailColor: '#3b82f6', 
      price: 0, 
      downloads: 1240,
      trailerUrl: "https://storage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4"
    },
    { 
      id: '2', 
      title: 'Nature Unveiled', 
      description: "Cinematic journey through unexplored wildlands.", 
      category: 'Nature', 
      thumbnailColor: '#10b981', 
      price: 0, 
      downloads: 3500,
      trailerUrl: "https://storage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4"
    },
    { 
      id: '3', 
      title: 'Tech Review 2024', 
      description: "The latest gadgets and software deep dives.", 
      category: 'Tech', 
      thumbnailColor: '#f59e0b', 
      price: 0, 
      downloads: 8900,
      trailerUrl: "https://storage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4"
    },
  ]);

  // Camera handling
  useEffect(() => {
    if ((screen === 'lobby' || screen === 'call') && !isVideoOff) {
      navigator.mediaDevices.getUserMedia({ video: true, audio: true })
        .then(stream => {
          if (videoRef.current) videoRef.current.srcObject = stream;
        })
        .catch(err => console.error("Camera access denied:", err));
    } else {
      if (videoRef.current && videoRef.current.srcObject) {
         const stream = videoRef.current.srcObject as MediaStream;
         stream.getTracks().forEach(track => track.stop());
         videoRef.current.srcObject = null;
      }
    }
  }, [screen, isVideoOff]);

  const generateIcebreaker = async () => {
    setIsLoadingIcebreaker(true);
    try {
      const response = await fetch('/api/chat-icebreaker', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ interest: 'shared goals and romance' }),
      });
      const data = await response.json();
      setIcebreaker(data.icebreaker);
    } catch (err) {
      setIcebreaker("What's your dream destination?");
    } finally {
      setIsLoadingIcebreaker(false);
    }
  };

  const generateAIVideo = async () => {
    if (!videoPrompt) return;
    setGenerating(true);
    try {
      const response = await fetch('/api/generate-video', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt: videoPrompt })
      });
      const data = await response.json();
      const movieData = { ...data, price: 3.99, downloads: 0 };
      setGeneratedVideo(movieData);
      setMovies(prev => [movieData, ...prev]);
      setVideoPrompt('');
    } catch (err) {
      console.error(err);
    } finally {
      setGenerating(false);
    }
  };

  const handleWatch = (movie: VideoItem) => {
    // Watching a video or trailer earns revenue from ads
    const watchRevenueValue = 0.15;
    setWatchRevenue(prev => prev + watchRevenueValue);
    setPlatformRevenue(prev => prev + watchRevenueValue);
    setSalesHistory(prev => [
      {
        date: new Date().toLocaleDateString(),
        movieTitle: `View: ${movie.title}`,
        amount: watchRevenueValue,
        buyer: "AdNet_VIEW_" + Math.random().toString(36).substr(2, 4).toUpperCase()
      },
      ...prev
    ]);
  };

  const handleFreeDownload = (movie: VideoItem) => {
    setIsDownloading(true);
    setDownloadProgress(0);
    
    // Simulate AD appearing
    const adRevenueValue = 0.45; // Owner earns 0.45 per download from ads

    const interval = setInterval(() => {
      setDownloadProgress(prev => {
        if (prev >= 100) {
          clearInterval(interval);
          setAdsRevenue(r => r + adRevenueValue);
          setPlatformRevenue(r => r + adRevenueValue);
          setSalesHistory(prev => [
            {
              date: new Date().toLocaleDateString(),
              movieTitle: `Download: ${movie.title}`,
              amount: adRevenueValue,
              buyer: "AdNet_DL_" + Math.random().toString(36).substr(2, 4).toUpperCase()
            },
            ...prev
          ]);
          setMovies(prevMovies => prevMovies.map(m => 
            m.id === movie.id ? { ...m, downloads: m.downloads + 1 } : m
          ));
          setTimeout(() => setIsDownloading(false), 800);
          return 100;
        }
        return prev + 10;
      });
    }, 100);
  };

  const handleDonate = (amount: number, movieTitle: string, isRecurring: boolean = false) => {
    setDonationRevenue(prev => prev + amount);
    if (isRecurring) {
      setRecurringRevenue(prev => prev + amount);
      setActiveDonors(prev => prev + 1);
    }
    setPlatformRevenue(prev => prev + amount);
    setSalesHistory(prev => [
      {
        date: new Date().toLocaleDateString(),
        movieTitle: `${isRecurring ? 'Monthly ' : ''}Donation: ${movieTitle}`,
        amount: amount,
        buyer: "Donor_" + Math.random().toString(36).substr(2, 4).toUpperCase(),
        isRecurring
      },
      ...prev
    ]);
    alert(`Thank you for your ${isRecurring ? 'monthly ' : ''}donation of $${amount}!`);
  };

  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file || !uploadTitle) return;

    setIsUploadingManual(true);
    setUploadProgress(0);

    const interval = setInterval(() => {
      setUploadProgress(prev => {
        if (prev >= 100) {
          clearInterval(interval);
          const newMovie: VideoItem = {
            id: Math.random().toString(36).substr(2, 9),
            title: uploadTitle,
            description: uploadDesc || "User uploaded content.",
            category: uploadCategory,
            thumbnailColor: '#' + Math.floor(Math.random()*16777215).toString(16),
            price: 0,
            downloads: 0,
            videoUrl: URL.createObjectURL(file)
          };
          setMovies(prev => [newMovie, ...prev]);
          setUploadTitle('');
          setUploadDesc('');
          setTimeout(() => setIsUploadingManual(false), 500);
          return 100;
        }
        return prev + 5;
      });
    }, 100);
  };

  const handleWithdraw = () => {
    const amount = parseFloat(withdrawAmount);
    if (isNaN(amount) || amount <= 0) return alert("Please enter a valid amount.");
    if (amount > platformRevenue) return alert("Insufficient balance.");
    if (!momoNumber.trim()) return alert("Please enter your Momo number.");
    if (!/^(078|079|072|073)\d{7}$/.test(momoNumber.trim())) return alert("Invalid MTN/Airtel-Tigo Momo number.");

    setIsProcessingWithdrawal(true);
    setTimeout(() => {
      setPlatformRevenue(prev => prev - amount);
      alert(`Withdrawal of $${amount} to ${momoNumber} successful! Funds will arrive in 1-2 hours.`);
      setWithdrawAmount('');
      setMomoNumber('');
      setIsProcessingWithdrawal(false);
    }, 2000);
  };

  return (
    <div className="min-h-screen bg-slate-50 font-sans overflow-x-hidden">
      
      {/* Dynamic Navbar */}
      <nav className="bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4 flex items-center justify-between sticky top-0 z-50">
        <div className="flex items-center gap-2 cursor-pointer" onClick={() => setScreen('landing')}>
          <div className="w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center shadow-lg transform active:scale-90 transition-transform">
            <Sparkles className="text-white w-5 h-5 fill-current" />
          </div>
          <span className="font-display font-bold text-xl tracking-tight text-slate-900 hidden sm:block">Connect World Wide</span>
        </div>

        <div className="flex bg-slate-100 p-1 rounded-full">
          {[
            { id: 'landing', label: 'Home' },
            { id: 'video-platform', label: 'Store' },
            { id: 'lobby', label: 'Community' },
            { id: 'dashboard', label: 'Dashboard' }
          ].map((item) => (
            <button
              key={item.id}
              onClick={() => setScreen(item.id as Screen)}
              className={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider transition-all ${
                screen === item.id ? 'bg-white text-slate-950 shadow-sm' : 'text-slate-500 hover:text-slate-900'
              }`}
            >
              {item.label}
            </button>
          ))}
        </div>

        <div className="flex items-center gap-4">
          <div className="hidden md:block text-right">
            <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Platform Rev</p>
            <p className="text-emerald-600 font-bold">${platformRevenue.toFixed(2)}</p>
          </div>
          <div className="w-10 h-10 bg-slate-900 rounded-full flex items-center justify-center text-white shadow-lg">
            <User size={18} />
          </div>
        </div>
      </nav>

      <AnimatePresence mode="wait">
        
        {/* Landing Screen */}
        {screen === 'landing' && (
          <motion.div 
            key="landing"
            initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, scale: 0.95 }}
            className="max-w-6xl mx-auto p-6 flex flex-col items-center justify-center min-h-[calc(100vh-100px)] text-center"
          >
            <motion.div 
               animate={{ rotate: [0, 10, -10, 0] }}
               transition={{ repeat: Infinity, duration: 5 }}
               className="w-24 h-24 bg-slate-900 rounded-[2rem] flex items-center justify-center mb-10 shadow-2xl"
            >
              <Sparkles className="text-white w-12 h-12" />
            </motion.div>
            <h1 className="text-5xl md:text-8xl font-display font-bold text-slate-900 mb-6 leading-tight">
              Watch Global. <span className="text-emerald-600">Free.</span>
            </h1>
            <p className="text-xl text-slate-600 mb-12 max-w-2xl leading-relaxed">
              Connect to the world's finest cinema and community. Watch everything for free, support creators with donations, and explore premium content.
            </p>
            <div className="flex flex-col sm:flex-row gap-4">
              <Button onClick={() => setScreen('video-platform')} className="px-12 py-5 text-lg bg-slate-900 hover:bg-slate-800">
                Browse Global Store
              </Button>
              <Button variant="outline" onClick={() => setScreen('lobby')} className="px-12 py-5 text-lg">
                Enter Community
              </Button>
            </div>
            
            <div className="mt-20 grid grid-cols-2 md:grid-cols-4 gap-4 w-full">
               {[
                 { label: 'Global Movies', value: '500+', icon: <Video className="text-slate-900" /> },
                 { label: 'Free Downloads', value: '45k', icon: <Download className="text-emerald-500" /> },
                 { label: 'Total Payouts', value: '$84k', icon: <TrendingUp className="text-amber-500" /> },
                 { label: 'Active Members', value: '1.2k', icon: <User className="text-blue-500" /> },
               ].map((stat, i) => (
                 <div key={i} className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-all">
                    <div className="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center mb-4 mx-auto">{stat.icon}</div>
                    <p className="text-2xl font-display font-bold text-slate-900">{stat.value}</p>
                    <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{stat.label}</p>
                 </div>
               ))}
            </div>
          </motion.div>
        )}

        {/* Video Store Screen */}
        {screen === 'video-platform' && (
          <motion.div 
            key="store"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="p-6 max-w-7xl mx-auto space-y-12 py-12"
          >
            <div className="flex flex-col md:flex-row md:items-end justify-between gap-6">
              <div>
                <h2 className="text-4xl font-display font-bold text-slate-900 mb-2 italic">Global Store</h2>
                <p className="text-slate-500 max-w-sm">Premium videos from creators worldwide. Completely free to watch and download.</p>
              </div>
              <div className="flex flex-col gap-6 w-full lg:w-auto">
                <div className="relative group">
                  <Search className="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-brand-500 transition-colors" size={18} />
                  <input 
                    type="text" 
                    placeholder="Search movies or keywords..."
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="w-full lg:w-80 bg-slate-100 border-none rounded-3xl py-4 pl-14 pr-6 focus:ring-4 focus:ring-brand-500/10 focus:bg-white transition-all outline-none text-slate-900 font-medium placeholder:text-slate-400"
                  />
                </div>
                <div className="flex flex-wrap gap-2 bg-slate-100 p-1.5 rounded-3xl">
                 {categories.map(cat => (
                   <button 
                    key={cat}
                    onClick={() => setSelectedCategory(cat)}
                    className={`px-5 py-2.5 rounded-2xl transition-all font-bold text-[10px] uppercase tracking-widest ${
                      selectedCategory === cat 
                        ? 'bg-white text-slate-900 shadow-sm' 
                        : 'text-slate-400 hover:text-slate-600'
                    }`}
                   >
                     {cat}
                   </button>
                 ))}
              </div>
            </div>
          </div>

            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
              {movies
                .filter(m => {
                  const matchesCategory = selectedCategory === 'All' || m.category === selectedCategory;
                  const matchesSearch = m.title.toLowerCase().includes(searchQuery.toLowerCase()) || 
                                        m.description.toLowerCase().includes(searchQuery.toLowerCase());
                  return matchesCategory && matchesSearch;
                })
                .map((movie) => (
                <motion.div 
                  key={movie.id}
                  whileHover={{ y: -8 }}
                  className="bg-white rounded-[3rem] overflow-hidden border border-slate-100 shadow-xl flex flex-col"
                >
                  <div 
                    className="aspect-video w-full flex items-center justify-center relative p-12 overflow-hidden"
                    style={{ backgroundColor: movie.thumbnailColor + '10' }}
                  >
                    <div 
                      className="w-16 h-16 rounded-2xl flex items-center justify-center text-white shadow-2xl transform transition-transform"
                      style={{ backgroundColor: movie.thumbnailColor }}
                    >
                       <Video size={32} />
                    </div>
                    <div className="absolute top-6 right-6 bg-emerald-500 backdrop-blur-md px-3 py-1.5 rounded-2xl shadow-sm">
                      <p className="text-xs font-bold text-white uppercase tracking-tighter">FREE</p>
                    </div>
                    {movie.trailerUrl && (
                      <button 
                        onClick={() => {
                          setActiveTrailer(movie);
                          handleWatch(movie);
                        }}
                        className="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer z-10"
                      >
                        <div className="w-14 h-14 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white ring-1 ring-white/50 border-white/30 border">
                           <div className="ml-1 border-y-[10px] border-y-transparent border-l-[15px] border-l-white" />
                        </div>
                      </button>
                    )}
                  </div>
                  <div className="p-8 flex-1 flex flex-col">
                    <div className="flex items-center gap-2 mb-2">
                       <span className="px-2 py-0.5 bg-slate-100 text-[10px] font-bold text-slate-500 rounded uppercase">{movie.category}</span>
                    </div>
                    <h3 className="text-2xl font-display font-bold text-slate-900 mb-4">{movie.title}</h3>
                    <p className="text-slate-500 text-sm mb-8 flex-1 leading-relaxed">{movie.description}</p>
                    <div className="flex items-center justify-between border-t border-slate-50 pt-6">
                      <div className="flex gap-4">
                        <div>
                          <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Views</p>
                          <p className="text-slate-800 font-bold">{(movie.downloads * 1.5).toFixed(0)}</p>
                        </div>
                        <div>
                          <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Saved</p>
                          <p className="text-slate-800 font-bold">{movie.downloads}</p>
                        </div>
                      </div>
                        <div className="flex flex-col gap-3">
                          <div className="flex gap-2">
                            {[2, 5, 10].map(amt => (
                              <button 
                                key={amt}
                                onClick={() => handleDonate(amt, movie.title)}
                                className="px-3 py-1.5 rounded-xl bg-rose-50 text-rose-500 font-bold text-[10px] hover:bg-rose-500 hover:text-white transition-colors"
                              >
                                ${amt}
                              </button>
                            ))}
                            <button 
                              onClick={() => handleDonate(20, movie.title, true)}
                              className="px-3 py-1.5 rounded-xl bg-brand-500 text-white font-bold text-[10px] hover:bg-brand-600 shadow-sm flex items-center gap-1"
                              title="Monthly Donation"
                            >
                              <Heart size={10} className="fill-current" /> $20/mo
                            </button>
                          </div>
                          <Button onClick={() => handleFreeDownload(movie)} className="bg-emerald-500 hover:bg-emerald-600 px-8 w-full">
                            <Download size={16} /> Watch & Save
                          </Button>
                          {movie.trailerUrl && (
                            <button 
                              onClick={() => {
                                setActiveTrailer(movie);
                                handleWatch(movie);
                              }}
                              className="text-xs font-bold text-slate-400 hover:text-brand-500 transition-colors uppercase tracking-widest text-center mt-2"
                            >
                              Play Trailer
                            </button>
                          )}
                        </div>
                    </div>
                  </div>
                </motion.div>
              ))}
            </div>
          </motion.div>
        )}

        {/* Dashboard / Admin Screen */}
        {screen === 'dashboard' && (
          <motion.div 
            key="dashboard"
            initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -20 }}
            className="p-6 max-w-7xl mx-auto space-y-10 py-12"
          >
            <div className="flex justify-between items-center bg-slate-900 p-8 rounded-[3rem] text-white overflow-hidden relative shadow-2xl">
               <Zap className="absolute -bottom-10 -right-10 w-48 h-48 opacity-5 text-brand-500" />
               <div className="relative z-10">
                  <h1 className="text-4xl font-display font-bold mb-2 italic">Owner's Command</h1>
                  <p className="text-slate-400 text-sm">Real-time performance tracking and content publishing.</p>
               </div>
               <div className="relative z-10 text-right">
                  <div className="flex gap-4">
                    <div className="hidden sm:block">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Ad Earnings</p>
                      <p className="text-xl font-bold text-emerald-400">${adsRevenue.toFixed(2)}</p>
                    </div>
                    <div className="hidden sm:block">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Watch Earnings</p>
                      <p className="text-xl font-bold text-blue-400">${watchRevenue.toFixed(2)}</p>
                    </div>
                    <div className="hidden sm:block">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Donations</p>
                      <p className="text-xl font-bold text-rose-400">${donationRevenue.toFixed(2)}</p>
                    </div>
                    <div className="hidden sm:block border-l border-white/10 pl-4">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Monthly Recur</p>
                      <p className="text-xl font-bold text-brand-400">${recurringRevenue.toFixed(2)}</p>
                    </div>
                    <div className="hidden sm:block">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Active Donors</p>
                      <p className="text-xl font-bold text-white">{activeDonors}</p>
                    </div>
                    <div>
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em] mb-1">Total Rev</p>
                      <p className="text-6xl font-display font-bold text-white font-mono tracking-tighter">${platformRevenue.toFixed(2)}</p>
                    </div>
                  </div>
               </div>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-2 gap-10">
               <div className="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm space-y-8">
                  <div className="flex items-center gap-3">
                    <div className="p-3 bg-brand-50 text-brand-500 rounded-2xl"><Sparkles /></div>
                    <h3 className="text-2xl font-display font-bold italic underline decoration-brand-200">AI Movie Generator</h3>
                  </div>
                  <div className="space-y-6">
                     <div className="space-y-2">
                        <label className="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-1">Describe Movie Concept</label>
                        <textarea 
                           value={videoPrompt}
                           onChange={(e) => setVideoPrompt(e.target.value)}
                           placeholder="Describe a new movie idea for the global market..."
                           className="w-full h-32 bg-slate-50 rounded-3xl p-6 border-none focus:ring-2 focus:ring-brand-500 outline-none transition-all placeholder:text-slate-300 text-lg leading-relaxed"
                        />
                     </div>
                     <Button 
                        onClick={generateAIVideo} 
                        className="w-full py-5 text-lg shadow-xl"
                        disabled={generating || !videoPrompt}
                     >
                        {generating ? 'Processing AI...' : 'Publish AI Movie'}
                     </Button>
                  </div>

                  <div className="pt-8 border-t border-slate-100 space-y-6">
                    <div className="flex items-center gap-3">
                      <div className="p-3 bg-emerald-50 text-emerald-500 rounded-2xl"><Upload size={20} /></div>
                      <h3 className="text-2xl font-display font-bold italic underline decoration-emerald-200">Manual Upload</h3>
                    </div>
                    <div className="space-y-4">
                      <input 
                        type="text" 
                        placeholder="Movie Title" 
                        value={uploadTitle}
                        onChange={(e) => setUploadTitle(e.target.value)}
                        className="w-full p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-emerald-500 font-bold"
                      />
                      <select 
                        value={uploadCategory}
                        onChange={(e) => setUploadCategory(e.target.value)}
                        className="w-full p-4 bg-slate-50 rounded-2xl border-none outline-none focus:ring-2 focus:ring-emerald-500 font-bold appearance-none"
                      >
                        {categories.filter(c => c !== 'All').map(c => <option key={c} value={c}>{c}</option>)}
                      </select>
                      <div className="relative">
                        <input 
                          type="file" 
                          accept="video/*" 
                          onChange={handleFileUpload}
                          className="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                          disabled={isUploadingManual || !uploadTitle}
                        />
                        <div className="w-full h-32 border-2 border-dashed border-slate-200 rounded-3xl flex flex-col items-center justify-center gap-2 bg-slate-50 group-hover:border-emerald-500 transition-colors">
                           {isUploadingManual ? (
                             <div className="w-full px-10 space-y-2">
                               <p className="text-xs font-bold text-slate-400 uppercase text-center">Uploading... {uploadProgress}%</p>
                               <div className="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                                 <div className="h-full bg-emerald-500 transition-all" style={{ width: `${uploadProgress}%` }} />
                               </div>
                             </div>
                           ) : (
                             <>
                               <Plus className="text-slate-400" />
                               <p className="text-xs font-bold text-slate-400 uppercase tracking-widest">Select Video File</p>
                             </>
                           )}
                        </div>
                      </div>
                    </div>
                  </div>
               </div>

               <div className="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden flex flex-col">
                  <div className="flex items-center gap-3 mb-8">
                    <div className="p-3 bg-slate-900 text-white rounded-2xl"><Layers size={20} /></div>
                    <h3 className="text-2xl font-display font-bold italic underline decoration-slate-200">Recent Sales Activity</h3>
                  </div>
                  <div className="flex-1 overflow-y-auto max-h-[300px] space-y-4 no-scrollbar">
                     {salesHistory.length > 0 ? salesHistory.map((sale, i) => (
                       <div key={i} className="flex items-center justify-between p-5 bg-slate-50 rounded-3xl border border-slate-100">
                          <div className="flex items-center gap-4">
                             <div className="w-12 h-12 bg-white rounded-2xl flex items-center justify-center border border-slate-100 italic font-display text-lg font-bold text-slate-400">{sale.movieTitle[0]}</div>
                             <div>
                                <p className="font-bold text-lg text-slate-800 leading-none mb-1">{sale.movieTitle}</p>
                                <p className="text-[10px] text-slate-400 font-mono tracking-widest">
                                  {sale.movieTitle.startsWith('View') 
                                    ? 'Ad Revenue from View' 
                                    : sale.movieTitle.startsWith('Download')
                                      ? 'Ad Revenue from Download'
                                      : sale.buyer.startsWith('Donor')
                                        ? `${sale.isRecurring ? 'Recurring ' : ''}Community Donation`
                                        : 'Platform Activity'}
                                </p>
                             </div>
                          </div>
                          <div className="text-right">
                             <p className={`${sale.movieTitle.startsWith('Donation') ? 'text-rose-600' : 'text-emerald-600'} font-bold text-lg leading-none mb-1`}>+${sale.amount.toFixed(2)}</p>
                             <p className="text-[10px] text-slate-400 uppercase font-bold tracking-widest">{sale.date}</p>
                          </div>
                       </div>
                     )) : (
                       <div className="h-full flex flex-col items-center justify-center opacity-30 italic text-slate-300 py-10">
                          <Zap size={48} className="mb-4" />
                          <p>Ready for takeoff. No sales yet.</p>
                       </div>
                     )}
                  </div>
               </div>
            </div>

            {/* Withdrawal Section */}
            <div className="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm">
                <div className="flex flex-col md:flex-row gap-12">
                    <div className="flex-1 space-y-6">
                        <div className="flex items-center gap-3">
                            <div className="p-3 bg-emerald-50 text-emerald-500 rounded-2xl"><CreditCard /></div>
                            <h3 className="text-2xl font-display font-bold italic underline decoration-emerald-200">Withdraw Revenue</h3>
                        </div>
                        <p className="text-slate-500">Withdraw your earnings directly to your MTN or Airtel-Tigo Mobile Money account.</p>
                        <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div className="space-y-2">
                                <label className="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-1">Amount ($)</label>
                                <input 
                                    type="number"
                                    value={withdrawAmount}
                                    onChange={(e) => setWithdrawAmount(e.target.value)}
                                    placeholder="0.00"
                                    className="w-full p-6 bg-slate-50 rounded-3xl border-none outline-none focus:ring-2 focus:ring-emerald-500 text-xl font-bold"
                                />
                            </div>
                            <div className="space-y-2">
                                <label className="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-1">Momo Number</label>
                                <input 
                                    type="text"
                                    value={momoNumber}
                                    onChange={(e) => setMomoNumber(e.target.value)}
                                    placeholder="078 XXX XXXX"
                                    className="w-full p-6 bg-slate-50 rounded-3xl border-none outline-none focus:ring-2 focus:ring-emerald-500 text-xl font-bold"
                                />
                            </div>
                        </div>
                        <Button 
                            variant="success" 
                            className="w-full py-6 text-xl shadow-xl"
                            onClick={handleWithdraw}
                            disabled={isProcessingWithdrawal || !withdrawAmount || !momoNumber}
                        >
                            {isProcessingWithdrawal ? 'Securely Processing...' : 'Withdraw via MTN Momo'}
                        </Button>
                    </div>
                    <div className="md:w-72 bg-emerald-500 rounded-[2.5rem] p-8 text-white relative overflow-hidden">
                        <Sparkles className="absolute -bottom-6 -right-6 w-32 h-32 opacity-10 rotate-12" />
                        <h4 className="font-display font-bold text-xl mb-4">Payout Info</h4>
                        <div className="space-y-4">
                            <div className="pb-4 border-b border-white/20">
                                <p className="text-[10px] font-bold text-white/60 uppercase tracking-widest mb-1">Fee</p>
                                <p className="font-bold">0.0% Rwanda Special</p>
                            </div>
                            <div className="pb-4 border-b border-white/20">
                                <p className="text-[10px] font-bold text-white/60 uppercase tracking-widest mb-1">Est. Time</p>
                                <p className="font-bold">Instant to 2 Hours</p>
                            </div>
                            <div>
                                <p className="text-[10px] font-bold text-white/60 uppercase tracking-widest mb-1">Status</p>
                                <p className="font-bold flex items-center gap-2"><span className="w-2 h-2 bg-white rounded-full animate-pulse" /> Gateway Active</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
          </motion.div>
        )}

        {/* Community / Lobby Screen */}
        {screen === 'lobby' && (
          <motion.div 
            key="lobby"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="flex flex-col items-center justify-center min-h-[calc(100vh-100px)] p-6"
          >
            <div className="w-full max-w-4xl bg-white rounded-[4rem] shadow-3xl p-3 overflow-hidden flex flex-col md:flex-row">
              <div className="md:w-1/2 bg-slate-900 rounded-[3.5rem] p-10 flex flex-col items-center justify-center relative min-h-[450px]">
                 <div className="absolute top-0 right-0 p-10 opacity-10"><Sparkles size={200} className="text-white" /></div>
                <div className="w-full aspect-[4/5] bg-slate-800 rounded-3xl overflow-hidden relative shadow-2xl ring-4 ring-white/10">
                  {!isVideoOff ? (
                    <video ref={videoRef} autoPlay muted playsInline className="w-full h-full object-cover scale-x-[-1]" />
                  ) : (
                    <div className="w-full h-full flex items-center justify-center text-slate-600 bg-slate-900"><Camera size={64} /></div>
                  )}
                  <div className="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-4">
                    <button onClick={() => setIsMuted(!isMuted)} className={`p-5 rounded-full transition-all ${isMuted ? 'bg-rose-500 text-white' : 'bg-white/10 text-white backdrop-blur-xl ring-1 ring-white/20'}`}>
                      {isMuted ? <MicOff size={24} /> : <Mic size={24} />}
                    </button>
                    <button onClick={() => setIsVideoOff(!isVideoOff)} className={`p-5 rounded-full transition-all ${isVideoOff ? 'bg-rose-500 text-white' : 'bg-white/10 text-white backdrop-blur-xl ring-1 ring-white/20'}`}>
                      {isVideoOff ? <VideoOff size={24} /> : <Video size={24} />}
                    </button>
                  </div>
                </div>
              </div>
              <div className="md:w-1/2 p-16 flex flex-col justify-center">
                 <div className="mb-12">
                    <h2 className="text-5xl font-display font-bold text-slate-900 mb-4 italic tracking-tighter">Global Meet.</h2>
                    <p className="text-slate-500 text-lg leading-relaxed">Connect with creators and fans from across the world. Introduce yourself and join the global dialogue.</p>
                 </div>
                 <div className="space-y-8">
                    <div className="group">
                       <label className="block text-[10px] font-bold text-slate-400 uppercase tracking-[0.4em] mb-3 px-1">Screen Name</label>
                       <input 
                         type="text" value={userName} onChange={(e) => setUserName(e.target.value)} 
                         placeholder="Enter your name..." 
                         className="w-full p-6 h-20 rounded-3xl bg-slate-50 border-none focus:ring-4 focus:ring-slate-900/10 focus:bg-white outline-none transition-all text-2xl font-display font-bold uppercase placeholder:text-slate-200"
                       />
                    </div>
                    <Button onClick={() => setScreen('call')} className="w-full py-6 text-xl shadow-2xl h-20 bg-slate-900" disabled={!userName.trim()}>
                       Join Video Stream
                    </Button>
                 </div>
              </div>
            </div>
          </motion.div>
        )}

        {/* Global Stream Screen */}
        {screen === 'call' && (
          <motion.div 
            key="call"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="h-[calc(100vh-80px)] bg-slate-950 flex flex-col md:flex-row p-4 gap-4"
          >
            <div className="flex-1 relative bg-slate-900 rounded-[3rem] overflow-hidden shadow-[0_0_100px_rgba(0,0,0,0.5)]">
               <div className="absolute inset-0 flex items-center justify-center">
                 <img 
                    src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?q=80&w=3000&auto=format&fit=crop" 
                    alt="Network" className="w-full h-full object-cover blur-md opacity-20 brightness-50"
                    referrerPolicy="no-referrer"
                 />
                 <div className="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent flex flex-col items-center justify-center">
                    <motion.div 
                      key="avatar"
                      animate={{ scale: [1, 1.05, 1] }} transition={{ repeat: Infinity, duration: 4 }}
                      className="w-56 h-56 rounded-full border-8 border-emerald-500 p-2 bg-slate-900 shadow-[0_0_50px_rgba(16,185,129,0.3)] relative"
                    >
                      <img 
                        src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=3276&auto=format&fit=crop" 
                        alt="Creator" className="w-full h-full object-cover rounded-full"
                        referrerPolicy="no-referrer"
                      />
                      <div className="absolute -bottom-2 -right-2 w-12 h-12 bg-emerald-500 rounded-full border-4 border-slate-900 flex items-center justify-center text-white"><Sparkles size={20} fill="currentColor" /></div>
                    </motion.div>
                    <h3 className="text-5xl font-display font-medium text-white italic mt-10 tracking-tighter">Alex Chen, Pro Creator</h3>
                    <p className="text-emerald-400 font-bold uppercase tracking-[0.5em] text-[10px] mt-4 flex items-center gap-2">
                       <span className="w-2 h-2 bg-emerald-500 rounded-full animate-pulse" /> Live Global Feed
                    </p>
                 </div>
               </div>
               
               {/* Self View */}
               <div className="absolute bottom-10 right-10 w-44 md:w-64 aspect-[3/4] bg-slate-800 rounded-[2.5rem] overflow-hidden border-4 border-white/5 shadow-3xl z-20">
                  {!isVideoOff ? (
                    <video ref={videoRef} autoPlay muted playsInline className="w-full h-full object-cover scale-x-[-1]" />
                  ) : (
                    <div className="w-full h-full flex items-center justify-center bg-slate-900 text-slate-700 italic font-display">Video Off</div>
                  )}
               </div>

               {/* Controls */}
               <div className="absolute bottom-10 left-1/2 -translate-x-1/2 flex items-center gap-6 z-30 bg-white/5 backdrop-blur-3xl p-4 rounded-[2.5rem] border border-white/5 shadow-2xl">
                  <button onClick={() => setIsMuted(!isMuted)} className={`p-6 rounded-full transition-all flex items-center justify-center w-20 h-20 ${isMuted ? 'bg-rose-500 text-white' : 'hover:bg-white/10 text-white'}`}>
                    {isMuted ? <MicOff size={32} /> : <Mic size={32} />}
                  </button>
                  <button onClick={() => setIsVideoOff(!isVideoOff)} className={`p-6 rounded-full transition-all flex items-center justify-center w-20 h-20 ${isVideoOff ? 'bg-rose-500 text-white' : 'hover:bg-white/10 text-white'}`}>
                    {isVideoOff ? <VideoOff size={32} /> : <Video size={32} />}
                  </button>
                  <button onClick={() => setScreen('landing')} className="p-6 rounded-full bg-rose-500 text-white shadow-2xl w-24 h-24 transform active:scale-90 transition-transform flex items-center justify-center group">
                    <LogOut size={40} className="group-hover:rotate-12 transition-transform" />
                  </button>
               </div>
            </div>

            {/* Sidebar Community Assistant */}
            <div className="w-full md:w-96 flex flex-col gap-4">
               <div className="flex-1 bg-white rounded-[4rem] p-10 shadow-3xl flex flex-col relative overflow-hidden border border-slate-100">
                  <div className="flex items-center gap-4 mb-10">
                    <div className="p-4 bg-emerald-50 text-emerald-600 rounded-[1.5rem] shadow-inner"><Sparkles size={24} /></div>
                    <h4 className="font-display font-bold text-slate-900 text-2xl italic tracking-tight underline decoration-emerald-200 decoration-4">Global Wing</h4>
                  </div>
                  <div className="flex-1 overflow-y-auto pb-6 no-scrollbar space-y-6">
                    {icebreaker ? (
                      <motion.div initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className="p-8 bg-slate-900 rounded-[2.5rem] text-white leading-relaxed font-display text-xl italic relative">
                        <MessageSquare className="absolute -top-4 -right-2 w-8 h-8 text-emerald-500 rotate-12" />
                        "{icebreaker}"
                      </motion.div>
                    ) : (
                      <div className="text-center text-slate-300 py-32 flex flex-col items-center">
                         <Sparkles size={48} className="mb-4 opacity-50" />
                         <p className="font-display italic text-lg leading-tight px-4">Starting a global conversation? We can help you break the ice.</p>
                      </div>
                    )}
                  </div>
                  <Button onClick={generateIcebreaker} disabled={isLoadingIcebreaker} className="w-full py-6 rounded-[2rem] shadow-emerald-500/20 text-xl font-display italic bg-emerald-500">
                    {isLoadingIcebreaker ? 'Generating spark...' : 'Get Conversation Starter'}
                  </Button>
               </div>
            </div>
          </motion.div>
        )}

      </AnimatePresence>

      {/* Trailer Modal */}
      <AnimatePresence>
        {activeTrailer && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[100] flex items-center justify-center p-6 sm:p-20 bg-slate-950/90 backdrop-blur-xl"
          >
            <motion.div 
              initial={{ scale: 0.9, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.9, opacity: 0 }}
              className="relative w-full max-w-5xl aspect-video bg-black rounded-[3rem] overflow-hidden shadow-2xl ring-1 ring-white/10"
            >
              <button 
                onClick={() => setActiveTrailer(null)}
                className="absolute top-8 right-8 z-50 w-12 h-12 bg-white/10 hover:bg-white/20 backdrop-blur-xl rounded-full flex items-center justify-center text-white transition-colors"
              >
                <X size={24} />
              </button>

              <video 
                src={activeTrailer.trailerUrl} 
                className="w-full h-full object-contain"
                autoPlay 
                controls 
              />
              
              <div className="absolute bottom-0 left-0 right-0 p-12 bg-gradient-to-t from-black via-black/50 to-transparent">
                 <h2 className="text-3xl font-display font-bold text-white mb-2">{activeTrailer.title}</h2>
                 <p className="text-slate-300 max-w-xl text-lg italic">Trailer Preview</p>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Cinematic Transaction Mask */}
      <AnimatePresence>
        {isDownloading && (
          <motion.div 
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="fixed inset-0 z-[100] bg-slate-950/95 backdrop-blur-2xl flex flex-col items-center justify-center p-8 text-white"
          >
            <motion.div 
              initial={{ scale: 0.8, opacity: 0 }} animate={{ scale: 1, opacity: 1 }}
              className="bg-white rounded-[5rem] p-16 max-w-md w-full text-center shadow-[0_0_100px_rgba(255,255,255,0.05)] text-slate-900 relative"
            >
              <div className="absolute -top-16 left-1/2 -translate-x-1/2 w-32 h-32 bg-brand-500 text-white rounded-[3rem] flex items-center justify-center shadow-2xl rotate-3 ring-[20px] ring-white">
                <CreditCard size={48} />
              </div>
              <div className="pt-8">
                <h3 className="text-4xl font-display font-bold mb-4 tracking-tighter italic">Securing Link.</h3>
                <p className="text-slate-500 text-lg mb-12 leading-relaxed font-medium">Preparing your global cinematic selection. This content is free to watch thanks to our community donors and ad partners.</p>
                
                <div className="relative h-4 bg-slate-100 rounded-full overflow-hidden mb-6 p-1 border border-slate-50">
                  <motion.div 
                    initial={{ width: 0 }}
                    animate={{ width: `${downloadProgress}%` }}
                    className="h-full bg-slate-900 rounded-full shadow-lg"
                  />
                </div>
                <div className="flex justify-between items-center px-2">
                   <p className="text-[10px] font-bold text-slate-400 uppercase tracking-[0.4em]">Encrypted Link</p>
                   <p className="text-xl font-display font-bold italic text-brand-600">{downloadProgress}%</p>
                </div>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      <style>{`
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        @keyframes pulse-ring {
          0% { transform: scale(.7); opacity: 0; }
          50% { opacity: .3; }
          100% { transform: scale(1.3); opacity: 0; }
        }
      `}</style>
    </div>
  );
}
